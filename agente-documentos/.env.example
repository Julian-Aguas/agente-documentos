# Configuración del Agente Local de Documentos
# Copy this file to .env and fill in your values

# URL del API LLM (debe ser compatible con OpenAI format)
# Ejemplos:
# - OpenRouter: https://openrouter.ai/api/v1/chat/completions
# - Azure OpenAI: https://[your-resource].openai.azure.com/
# - Local OpenAI-compatible: http://localhost:8000/v1/chat/completions
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Tu clave de API (REQUERIDO)
# Obtén una en: https://openrouter.ai/keys
LLM_API_KEY=

# Modelo a utilizar (opcional, default: mistralai/mistral-7b-instruct:free)
# Otros modelos de OpenRouter:
# - openai/gpt-3.5-turbo
# - meta-llama/llama-2-70b
# - anthropic/claude-2
# - mistralai/mistral-7b-instruct:free
LLM_MODEL=mistralai/mistral-7b-instruct:free
